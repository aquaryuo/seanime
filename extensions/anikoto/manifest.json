{
  "id": "anikoto",
  "name": "Anikoto",
  "version": "1.3.29",
  "manifestURI": "https://raw.githubusercontent.com/aquaryuo/seanime/main/extensions/anikoto/manifest.json",
  "language": "typescript",
  "type": "onlinestream-provider",
  "description": "Only anikoto compatibility layer you'll ever need",
  "author": "aquaryuo",
  "icon": "https://raw.githubusercontent.com/aquaryuo/seanime/main/extensions/anikoto/icon.png",
  "website": "https://anikototv.to",
  "lang": "en",
  "payloadURI": "https://raw.githubusercontent.com/aquaryuo/seanime/main/extensions/anikoto/provider.ts",
  "userConfig": {
    "version": 2,
    "requiresConfig": false,
    "fields": [
      {
        "type": "select",
        "name": "baseUrl",
        "label": "Site / mirror domain",
        "default": "https://anikototv.to",
        "options": [
          { "value": "https://anikototv.to", "label": "anikototv.to" },
          { "value": "https://anikoto.cz", "label": "anikoto.cz" },
          { "value": "https://anikoto.me", "label": "anikoto.me" },
          { "value": "https://anikoto.net", "label": "anikoto.net" },
          { "value": "https://anikototv.se", "label": "anikototv.se" }
        ]
      }
    ]
  }
}
